# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Optional Postgres aliases
POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
POSTGRES_USER="USER"
POSTGRES_PASSWORD="PASSWORD"
POSTGRES_HOST="HOST"
POSTGRES_DATABASE="DB"

# File downloads
CLOUDFRONT_DOMAIN="your-cloudfront-domain.example.com"

# S3 upload signing
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
AWS_REGION="us-east-1"
S3_BUCKET="your-bucket-name"
QUEUE_S3_BUCKET="your-queue-bucket-name"
QUEUE_CLOUDFRONT_DOMAIN="your-cloudfront-domain.example.com"
QUEUE_S3_PREFIX="queue"
APP_DEPLOY_MAX_DRIFT_SECONDS="1800"
# Optional: force backend build timestamp in milliseconds.
# If empty, backend start time is used automatically.
APP_BUILD_TS=""
