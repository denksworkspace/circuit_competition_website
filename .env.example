# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Optional Postgres aliases
POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
POSTGRES_USER="USER"
POSTGRES_PASSWORD="PASSWORD"
POSTGRES_HOST="HOST"
POSTGRES_DATABASE="DB"
USE_RESERVE_DB="1"
RESERVE_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
RESERVE_POSTGRES_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
# Backward-compatible reserve aliases (optional)
DATABASE_URL_RESERVE=""
POSTGRES_URL_RESERVE=""
MAINTENANCE_ENABLED_REFRESH_MS="15000"
SITE_ACTIVITY_LOGGING_ENABLED="0"

# File downloads
CLOUDFRONT_DOMAIN="your-cloudfront-domain.example.com"

# S3 upload signing
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
AWS_REGION="us-east-1"
S3_BUCKET="your-bucket-name"
QUEUE_S3_BUCKET="your-queue-bucket-name"
QUEUE_CLOUDFRONT_DOMAIN="your-cloudfront-domain.example.com"
QUEUE_S3_PREFIX="queue"
